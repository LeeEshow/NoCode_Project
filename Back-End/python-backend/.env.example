# Firebase / Firestore
FIRESTORE_PROJECT_ID=nocode-finance
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON=<base64-encoded-json>  # Azure 部署用，與上方二擇一

# Server
PORT=8000

# 本機開發：設為 true 時跳過 EasyAuth 驗證
SKIP_AUTH=true

# Shioaji（選填，未設定時全程使用 Yahoo Finance）
SJ_API_KEY=
SJ_SECRET_KEY=

# MCP Server（production 必填；未設定且非 dev 環境時 MCP 端點回 503）
MCP_ACCESS_KEY=

# CORS 允許的前端來源（逗號分隔；未設定時預設 localhost:5173,localhost:3000）
# production 範例：ALLOWED_ORIGINS=https://your-frontend.azurestaticapps.net
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
