# Firebase / Firestore
FIRESTORE_PROJECT_ID=nocode-finance
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json   # 本機開發
# GOOGLE_APPLICATION_CREDENTIALS_JSON=<base64 JSON>       # Azure 部署（二擇一）

# Shioaji（選填；未設定時全程使用 Yahoo Finance）
SJ_API_KEY=your_api_key_here
SJ_SECRET_KEY=your_secret_key_here

# MCP Server
MCP_ACCESS_KEY=your_mcp_access_key_here

# Auth（本機開發設 true 跳過 Easy Auth 驗證）
SKIP_AUTH=false

# Server
PORT=8080
