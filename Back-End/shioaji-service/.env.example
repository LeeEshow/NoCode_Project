# ── 必填：永豐金 API 金鑰 ──────────────────────────────────────────────────
SJ_API_KEY=你的永豐金API_KEY
SJ_SECRET_KEY=你的永豐金SECRET_KEY

# ── 環境模式（預設 false = 正式環境）─────────────────────────────────────
# 設為 true 時使用模擬環境（simulation=True），不需 CA 憑證
SJ_SIMULATION=false

# ── CA 憑證設定（正式環境下單必填）──────────────────────────────────────
# 僅正式環境需要，模擬環境可留空
# 執行 python verify_env.py --activate-ca 一次性啟用後，服務啟動時會自動套用
SJ_CA_PATH=./ca.pfx
SJ_CA_PASSWD=你的憑證密碼
SJ_PERSON_ID=你的身分證字號
